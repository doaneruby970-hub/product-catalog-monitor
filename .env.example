DATABASE_URL=postgresql://postgres:postgres@postgres:5432/upwork_demo
API_HOST=0.0.0.0
API_PORT=5000
LOG_LEVEL=INFO
BROWSER_BACKEND=cdp
CDP_URL=http://host.docker.internal:9223
HEADLESS=true
BROWSER_TIMEOUT_MS=45000
PAGE_LOAD_WAIT_MS=15000
REQUEST_DELAY_SECONDS=2
MAX_RETRIES=3
MISSING_THRESHOLD=2
EXPORT_DIR=/app/exports
